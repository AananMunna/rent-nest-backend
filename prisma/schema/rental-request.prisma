model RentalRequest {
  id            String               @id @default(uuid())
  propertyId    String
  property      Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        User                 @relation("TenantRequests", fields: [tenantId], references: [id], onDelete: Cascade)
  landlordId    String
  landlord      User                 @relation("LandlordRequests", fields: [landlordId], references: [id], onDelete: Cascade)
  moveInDate    DateTime
  moveOutDate   DateTime?
  message       String?              @db.Text
  status        RentalRequestStatus   @default(PENDING)
  approvedAt    DateTime?
  rejectedAt    DateTime?
  completedAt   DateTime?
  payment       Payment?
  review        Review?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([propertyId])
  @@index([tenantId])
  @@index([landlordId])
  @@map("rental_requests")
}