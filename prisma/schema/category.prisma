model Category {
  id          String    @id @default(uuid())
  name        String    @unique @db.VarChar(120)
  slug        String    @unique @db.VarChar(140)
  description String?   @db.Text
  properties  Property[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}